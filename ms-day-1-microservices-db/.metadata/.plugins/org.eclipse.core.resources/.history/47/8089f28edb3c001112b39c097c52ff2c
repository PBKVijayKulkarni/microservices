server:
  port: 8080

spring:
  cloud:
    gateway:
      routes:
        - id: user-service
          uri: lb://USER-SERVICE
          predicates:
            - Path=/users/**

        - id: logistics-service
          uri: lb://LOGISTICS-SERVICE
          predicates:
            - Path=/logistics/**

        - id: billing-service
          uri: lb://BILLING-SERVICE
          predicates:
            - Path=/billing/**

eureka:
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka/